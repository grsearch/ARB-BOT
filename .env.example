# ===== 币安 =====
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ===== BSC =====
# 推荐新加坡节点的付费私有RPC:
# https://go.getblock.io/xxxxxxxx/
# https://bsc-mainnet.nodereal.io/v1/xxxx
# https://xxx.bsc.quiknode.pro/xxxx/
BSC_RPC_HTTP=https://your-primary-bsc-rpc
BSC_RPC_WS=wss://your-primary-bsc-ws
BSC_RPC_BACKUP=https://bsc-dataseed.binance.org

WALLET_PRIVATE_KEY=0xyour_wallet_private_key
WALLET_ADDRESS=0xyour_wallet_address

# ===== Birdeye =====
BIRDEYE_API_KEY=your_birdeye_premium_plus_key

# ===== Telegram (可选) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 服务 =====
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# ===== 风控参数（也可在Dashboard中实时修改）=====
ENTRY_THRESHOLD=0.025        # 2.5% 基差开仓
EXIT_THRESHOLD=0.005         # 0.5% 基差平仓
POSITION_USDT=500            # 单笔USDT金额
MAX_SLIPPAGE=0.012           # 1.2% 最大滑点
LEVERAGE=3                   # 杠杆倍数
MAX_CONCURRENT_POSITIONS=2   # 最多同时持仓数
MAX_EXEC_LATENCY_MS=2000     # 超过则强制平仓
DRY_RUN=true                 # true=模拟，不真实下单（首次部署必须保持true）

# ===== 扫描参数 =====
SCAN_INTERVAL_SEC=120        # 每 2 分钟扫描一次
TOP_N_GAINERS=30             # 币安涨幅榜 Top N
MIN_24H_GAIN_PCT=0.02        # 至少 2% 涨幅才进候选
MIN_POOL_TVL_USD=10000       # 池子 TVL 下限 (0=不过滤)
MAX_POOL_FEE_BPS=10000       # 最大池子 fee (10000=1%, 2500=0.25%)
ENABLED=true                 # 总开关

# ===== 手续费 =====
CEX_TAKER_FEE=0.00045        # 币安 USDT-M taker 费率（开BNB抵扣后约0.045%）
CEX_MAKER_FEE=0.00018

# ===== Gas =====
GAS_BOOST_MULTIPLIER=1.5      # 对链上base gas_price的乘数。1.0=不加价；2.0=2倍抢速度。
                              # BSC基础gas通常1 Gwei，2倍=2 Gwei，让验证者优先打包。
                              # 实测：1.5→DEX confirm ~900ms，2.5→~450ms

# ===== 安全保护 =====
MIN_BNB_BALANCE=0.002         # BNB 余额下限，低于此值停止发DEX TX，防止gas耗尽后继续烧
SYMBOL_BLACKLIST=             # 逗号分隔的黑名单，例如 ONUSDT,FAKEUSDT
                              # 貔貅盘或卖出受限币加到这里，scanner和engine都会拦截
